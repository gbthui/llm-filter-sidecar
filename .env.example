# The upstream must be reachable from the sidecar container.
UPSTREAM_URL=http://host.docker.internal:3000
# Optional. When empty, readiness checks only the redaction service.
UPSTREAM_HEALTH_URL=

BIND_ADDRESS=127.0.0.1
GATEWAY_PORT=8080
REDACTION_TIMEOUT=2s
# Match the owner of file-backed secrets on Linux (`id -u` / `id -g`).
SIDECAR_UID=1000
SIDECAR_GID=1000

# Optional semantic audit; used only with compose.audit.yaml.
AUDIT_URL=https://audit.example/v1/chat/completions
AUDIT_MODEL=your-audit-model
AUDIT_ALLOW_INSECURE_HTTP=false
AUDIT_MODEL_LIST_MODE=allow
AUDIT_TIMEOUT=10s
AUDIT_MAX_INPUT_BYTES=262144
